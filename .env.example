# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================

# MySQL (Prisma)
DATABASE_URL="mysql://usuario:password@localhost:3306/mariavita"

# MongoDB (Mongoose)
MONGODB_URI="mongodb://localhost:27017/mariavita"

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# Puerto del backend Express
BACKEND_PORT=5000

# Host donde escucha el backend
BACKEND_HOST=0.0.0.0

# Orígenes permitidos por CORS (separados por coma)
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000

# Compatibilidad con configuración anterior
FRONTEND_URL=http://localhost:3000

# URL interna del backend usada por Next.js para el proxy /api
BACKEND_INTERNAL_URL=http://127.0.0.1:5000/api

# URL pública de la API para el cliente; mantener /api para usar el proxy
NEXT_PUBLIC_API_URL=/api

# ============================================
# AUTENTICACIÓN Y SEGURIDAD
# ============================================

# Secret para JWT (generar uno seguro en producción)
JWT_SECRET=tu_secret_super_seguro_cambiar_en_produccion
JWT_EXPIRES_IN=7d

# Secret para cookies
COOKIE_SECRET=otro_secret_para_cookies

# ============================================
# SERVICIOS EXTERNOS (FUTUROS)
# ============================================

# Servicio de email (ej: SendGrid, AWS SES)
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=
# EMAIL_FROM=noreply@mariavita.com

# Almacenamiento de archivos (ej: AWS S3, Azure Blob)
# STORAGE_SERVICE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=

# IA / generación de imágenes (opcionales)
HUGGING_FACE_API_KEY=
HUGGING_FACE_MODEL=stabilityai/stable-diffusion-2-1
REPLICATE_API_TOKEN=

# Pasarela de pago (ej: Stripe, Conekta)
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================

# Nivel de logs (error, warn, info, debug)
LOG_LEVEL=debug

# ============================================
# RATE LIMITING
# ============================================

# Límite de requests por ventana de tiempo
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
