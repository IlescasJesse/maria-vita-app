# ============================================
# PRODUCCIÓN - VPS Ubuntu Maria Vita
# Dominio: https://maria-vita.mx
# Copiar a .env.production y ajustar solo si cambia la infraestructura
# ============================================

NODE_ENV=production

# MySQL local en el VPS
DATABASE_URL="mysql://root:@127.0.0.1:3306/mariavita"

# MongoDB local en el VPS
MONGODB_URI="mongodb://127.0.0.1:27017/mariavita"

# Seguridad
JWT_SECRET="CAMBIAR_POR_UN_SECRET_LARGO_Y_ALEATORIO"
JWT_EXPIRES_IN=7d
COOKIE_SECRET="CAMBIAR_POR_OTRO_SECRET_LARGO_Y_ALEATORIO"

# Backend Express
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000

# Frontend / proxy / CORS
PORT=3000
FRONTEND_URLS="https://maria-vita.mx,https://www.maria-vita.mx"
FRONTEND_URL="https://maria-vita.mx"
BACKEND_INTERNAL_URL="http://127.0.0.1:5000/api"
NEXT_PUBLIC_API_URL="/api"

# Servicios opcionales
HUGGING_FACE_API_KEY=""
HUGGING_FACE_MODEL="stabilityai/stable-diffusion-2-1"
REPLICATE_API_TOKEN=""